{
  "name": "indexa-code-intelligence",
  "displayName": "Indexa — Code Intelligence Engine",
  "description": "Trace execution flows, find references, and understand code instantly. Stop reading files manually — ask Indexa, click the answer, jump to the line.",
  "version": "0.4.0",
  "publisher": "PrashantSingh",
  "author": {
    "name": "Prashant Singh",
    "url": "https://prashantsinghmangat.netlify.app/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prashantsinghmangat/Indexa"
  },
  "homepage": "https://github.com/prashantsinghmangat/Indexa",
  "icon": "media/extension-icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Other"],
  "keywords": [
    "code intelligence",
    "code search",
    "execution flow",
    "code tracing",
    "MCP",
    "AI context",
    "token reduction",
    "codebase understanding",
    "symbol search",
    "references"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "indexa",
          "title": "Indexa",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "indexa": [
        {
          "id": "indexaSidebar",
          "name": "Code Intelligence",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "indexaSidebar",
        "contents": "Ask Indexa anything about your codebase.\n[Search Code](command:indexa.sidebarSearch)\n[Trace Flow](command:indexa.sidebarFlow)\n[Find References](command:indexa.sidebarReferences)"
      }
    ],
    "commands": [
      {
        "command": "indexa.ask",
        "title": "Ask Indexa",
        "icon": "$(search)"
      },
      {
        "command": "indexa.sidebarSearch",
        "title": "Indexa: Search in Sidebar",
        "icon": "$(search)"
      },
      {
        "command": "indexa.sidebarFlow",
        "title": "Indexa: Trace Flow",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "indexa.sidebarReferences",
        "title": "Indexa: Find References",
        "icon": "$(references)"
      },
      {
        "command": "indexa.explain",
        "title": "Indexa: Explain This"
      },
      {
        "command": "indexa.flow",
        "title": "Indexa: Show Flow"
      },
      {
        "command": "indexa.references",
        "title": "Indexa: Find References"
      },
      {
        "command": "indexa.reindex",
        "title": "Indexa: Reindex Project"
      },
      {
        "command": "indexa.health",
        "title": "Indexa: Health Check"
      },
      {
        "command": "indexa.explainSelection",
        "title": "Indexa: Explain This",
        "icon": "$(lightbulb)"
      },
      {
        "command": "indexa.fixThis",
        "title": "Indexa: Fix This",
        "icon": "$(wrench)"
      },
      {
        "command": "indexa.whatCallsThis",
        "title": "Indexa: What Calls This?",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "indexa.refactorThis",
        "title": "Indexa: Refactor This",
        "icon": "$(edit)"
      },
      {
        "command": "indexa.generateTests",
        "title": "Indexa: Generate Tests",
        "icon": "$(beaker)"
      },
      {
        "command": "indexa.copyForAI",
        "title": "Indexa: Copy Context for AI",
        "icon": "$(clippy)"
      },
      {
        "command": "indexa.fixBug",
        "title": "Indexa: Fix Bug (clipboard)",
        "icon": "$(bug)"
      },
      {
        "command": "indexa.openForCopilot",
        "title": "Indexa: Open Files for Copilot",
        "icon": "$(files)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "indexa.sidebarSearch",
          "when": "view == indexaSidebar",
          "group": "navigation@1"
        },
        {
          "command": "indexa.sidebarFlow",
          "when": "view == indexaSidebar",
          "group": "navigation@2"
        },
        {
          "command": "indexa.sidebarReferences",
          "when": "view == indexaSidebar",
          "group": "navigation@3"
        }
      ],
      "editor/context": [
        {
          "submenu": "indexa.contextSubmenu",
          "group": "indexa@1"
        }
      ],
      "indexa.contextSubmenu": [
        {
          "command": "indexa.explainSelection",
          "group": "1_understand@1"
        },
        {
          "command": "indexa.fixThis",
          "group": "1_understand@2"
        },
        {
          "command": "indexa.whatCallsThis",
          "group": "1_understand@3"
        },
        {
          "command": "indexa.refactorThis",
          "group": "2_improve@1"
        },
        {
          "command": "indexa.generateTests",
          "group": "2_improve@2"
        },
        {
          "command": "indexa.copyForAI",
          "group": "3_export@1"
        },
        {
          "command": "indexa.openForCopilot",
          "group": "3_export@2"
        }
      ]
    },
    "submenus": [
      {
        "id": "indexa.contextSubmenu",
        "label": "Indexa",
        "icon": "$(search)"
      }
    ],
    "configuration": {
      "title": "Indexa",
      "properties": {
        "indexa.serverUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Indexa REST API server URL"
        },
        "indexa.dataDir": {
          "type": "string",
          "default": "",
          "description": "Path to Indexa data directory (leave empty for default)"
        },
        "indexa.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to Indexa CLI (node dist/cli/index.js). Leave empty to use REST API."
        },
        "indexa.defaultTokenBudget": {
          "type": "number",
          "default": 4000,
          "description": "Default token budget for context bundles (4000 = ~8-12 symbols with code)"
        }
      }
    },
    "keybindings": [
      {
        "command": "indexa.ask",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      },
      {
        "command": "indexa.fixThis",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorTextFocus"
      },
      {
        "command": "indexa.explainSelection",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "package": "vsce package",
    "install-ext": "code --install-extension indexa-0.1.0.vsix"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.10.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.2"
  }
}
