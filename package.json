{
  "name": "indexa",
  "version": "3.0.0",
  "description": "Indexa — Code intelligence via MCP. Context bundles, execution flow tracing, code explanation, BM25 + semantic search, byte-offset retrieval, dependency graphs, and LRU query cache.",
  "main": "dist/src/server/index.js",
  "bin": {
    "indexa": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/server/index.js",
    "dev": "ts-node src/server/index.ts",
    "cli": "ts-node cli/index.ts",
    "indexa": "node dist/cli/index.js",
    "mcp": "node dist/src/mcp/stdio.js"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ts-morph": "^21.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
